{
  "name": "quick-publish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "多平台内容发布桌面应用 - 本地内容基座",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.2.6",
    "tdesign-vue-next": "^1.10.5",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/markdown-it": "^14.1.2",
    "@unocss/preset-wind3": "^66.7.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.6.3",
    "unocss": "^66.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
